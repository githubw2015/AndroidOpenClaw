<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

  <!-- 主画布以中心 54,54 为原点 -->
  <group
      android:translateX="54"
      android:translateY="54">

    <!-- 背景圆形 - 渐变蓝色 -->
    <path
        android:pathData="M0,-30 A30,30 0 1,1 0,30 A30,30 0 1,1 0,-30Z"
        android:fillColor="#2563EB"/>

    <!-- 内圈微光 -->
    <path
        android:pathData="M0,-26 A26,26 0 1,1 0,26 A26,26 0 1,1 0,-26Z"
        android:fillColor="#3B82F6"
        android:fillAlpha="0.5"/>

    <!-- 爪印主体 - 大肉垫 (椭圆) -->
    <path
        android:pathData="M0,6 A11,9 0 1,1 0.01,6Z"
        android:fillColor="#FFFFFF"/>

    <!-- 爪印 - 左上趾 -->
    <path
        android:pathData="M-12,-8 A4.5,5.5 -20 1,1 -11.99,-8Z"
        android:fillColor="#FFFFFF"/>

    <!-- 爪印 - 左中趾 -->
    <path
        android:pathData="M-5,-16 A4,5.5 -5 1,1 -4.99,-16Z"
        android:fillColor="#FFFFFF"/>

    <!-- 爪印 - 右中趾 -->
    <path
        android:pathData="M5,-16 A4,5.5 5 1,1 5.01,-16Z"
        android:fillColor="#FFFFFF"/>

    <!-- 爪印 - 右上趾 -->
    <path
        android:pathData="M12,-8 A4.5,5.5 20 1,1 12.01,-8Z"
        android:fillColor="#FFFFFF"/>

    <!-- Android 天线 - 左 -->
    <path
        android:pathData="M-4,-20 L-7,-26"
        android:strokeColor="#60A5FA"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"/>

    <!-- Android 天线 - 右 -->
    <path
        android:pathData="M4,-20 L7,-26"
        android:strokeColor="#60A5FA"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"/>

    <!-- 天线顶端小圆点 - 左 -->
    <path
        android:pathData="M-7,-26 A1.2,1.2 0 1,1 -6.99,-26Z"
        android:fillColor="#60A5FA"/>

    <!-- 天线顶端小圆点 - 右 -->
    <path
        android:pathData="M7,-26 A1.2,1.2 0 1,1 7.01,-26Z"
        android:fillColor="#60A5FA"/>

    <!-- 肉垫上的电路纹路 - 水平线 -->
    <path
        android:pathData="M-5,5 L5,5"
        android:strokeColor="#3B82F6"
        android:strokeWidth="0.8"
        android:strokeLineCap="round"
        android:fillAlpha="0"/>

    <!-- 肉垫上的电路纹路 - 竖线 -->
    <path
        android:pathData="M0,1 L0,9"
        android:strokeColor="#3B82F6"
        android:strokeWidth="0.8"
        android:strokeLineCap="round"
        android:fillAlpha="0"/>

    <!-- 电路节点小点 -->
    <path
        android:pathData="M-5,5 A0.8,0.8 0 1,1 -4.99,5Z"
        android:fillColor="#2563EB"/>
    <path
        android:pathData="M5,5 A0.8,0.8 0 1,1 5.01,5Z"
        android:fillColor="#2563EB"/>
    <path
        android:pathData="M0,5 A0.8,0.8 0 1,1 0.01,5Z"
        android:fillColor="#2563EB"/>

